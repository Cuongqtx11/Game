    "intermediate": [
      {
        "pattern": "-아/어서",
        "title": "Nối nguyên nhân hoặc trình tự",
        "example": "바빠서 못 갔어요."
      },
      {
        "pattern": "-려고 해요",
        "title": "Dự định làm gì",
        "example": "주말에 여행하려고 해요."
      },
      {
        "pattern": "-지만",
        "title": "Nhưng / tuy nhiên",
        "example": "비싸지만 좋아요."
      }
    ],
    "advanced": [
      {
        "pattern": "-는 것 같습니다",
        "title": "Suy đoán mềm mại",
